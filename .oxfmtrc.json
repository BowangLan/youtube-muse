{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    "**/node_modules/**",
    "**/.next/**",
    "**/dist/**",
    "**/.electron-build/**",
    "apps/web/convex/_generated/**",
    "docs/**",
    "AGENTS.md",
    "CLAUDE.md",
    "YOUTUBE_API_SETUP.md",
    "YOUTUBE_API_USAGE.md",
    "soutyt_data.json"
  ],
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "sortImports": false,
  "sortPackageJson": false,
  "sortTailwindcss": false
}
